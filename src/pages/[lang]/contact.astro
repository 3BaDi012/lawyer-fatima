---
import { Mail, MessageCircle, Phone } from 'lucide-astro';
import ContactForm from '../../components/ContactForm.astro';
import GoogleMap from '../../components/GoogleMap.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import seo from '../../content/data/seo.json';
import site from '../../content/data/site.json';
import ui from '../../content/data/ui.json';
import { localeHref } from '../../utils/locale-path';
import { isLang, type Lang } from '../../utils/types';

export function getStaticPaths() {
  return [{ params: { lang: 'ar' } }, { params: { lang: 'en' } }];
}

const raw = Astro.params.lang;
if (!isLang(raw)) {
  throw new Error('Invalid language');
}

const lang: Lang = raw;
const t = ui[lang];
const s = seo[lang];
const wa = `https://wa.me/${site.whatsappDigits}`;
const tel = `tel:${site.phoneTel}`;
const email = site.email.trim();
---

<SiteLayout lang={lang} title={s.contactTitle} description={s.contactDescription} pathKey="contact" includeLegalJsonLd>
  <div class="mx-auto max-w-6xl px-6 py-14 sm:py-16">
    <h1 class="text-4xl font-semibold text-brand-navy sm:text-5xl">{t.contactHeading}</h1>
    <p class="mt-5 max-w-3xl text-lg text-brand-muted">{t.contactIntro}</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      <a
        href={tel}
        class="flex items-center gap-3 rounded-lg border border-brand-navy/10 bg-white px-4 py-4 text-brand-navy shadow-sm no-underline hover:border-brand-gold/50"
      >
        <Phone class="h-6 w-6 shrink-0 text-brand-gold" aria-hidden="true" />
        <span>
          <span class="block text-xs font-semibold text-brand-muted">{t.callCta}</span>
          <span class="block font-mono text-sm font-semibold">{site.phoneDisplay}</span>
        </span>
      </a>

      <a
        href={wa}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 rounded-lg border border-brand-navy/10 bg-white px-4 py-4 text-brand-navy shadow-sm no-underline hover:border-brand-gold/50"
      >
        <MessageCircle class="h-6 w-6 shrink-0 text-brand-gold" aria-hidden="true" />
        <span>
          <span class="block text-xs font-semibold text-brand-muted">{t.whatsappCta}</span>
          <span class="block text-sm font-semibold">{t.whatsappBrand}</span>
        </span>
      </a>

      {
        email ? (
          <a
            href={`mailto:${email}`}
            class="flex items-center gap-3 rounded-lg border border-brand-navy/10 bg-white px-4 py-4 text-brand-navy shadow-sm no-underline hover:border-brand-gold/50"
          >
            <Mail class="h-6 w-6 shrink-0 text-brand-gold" aria-hidden="true" />
            <span>
              <span class="block text-xs font-semibold text-brand-muted">{t.emailCta}</span>
              <span class="block text-sm font-semibold break-all">{email}</span>
            </span>
          </a>
        ) : (
          <div class="flex items-center gap-3 rounded-lg border border-brand-navy/10 bg-brand-cream/60 px-4 py-4 text-brand-muted">
            <Mail class="h-6 w-6 shrink-0 text-brand-gold/70" aria-hidden="true" />
            <span>
              <span class="block text-xs font-semibold">{t.emailCta}</span>
              <span class="block text-sm">{t.emailUnavailable}</span>
            </span>
          </div>
        )
      }
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-semibold text-brand-navy">{t.contactMapHeading}</h2>
        <div class="mt-4">
          <GoogleMap lang={lang} />
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-muted">{lang === 'ar' ? site.addressAr : site.addressEn}</p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-brand-navy">{t.contactHoursHeading}</h2>
        <ul class="mt-4 space-y-2 text-brand-muted">
          {(lang === 'ar' ? site.officeHoursLinesAr : site.officeHoursLinesEn).map((line) => <li>{line}</li>)}
        </ul>
        <p class="mt-4 text-sm text-brand-muted">{lang === 'ar' ? site.officeHoursNoteAr : site.officeHoursNoteEn}</p>
        <p class="mt-6 text-sm">
          <a class="font-semibold text-brand-navy underline-offset-4 hover:underline" href={localeHref(lang, 'privacy')}>
            {t.navPrivacy}
          </a>
        </p>
      </div>
    </div>

    <div class="mt-14">
      <ContactForm lang={lang} />
    </div>
  </div>
</SiteLayout>
