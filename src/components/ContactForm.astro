---
import practiceAreas from '../content/data/practice-areas.json';
import site from '../content/data/site.json';
import ui from '../content/data/ui.json';
import type { Lang } from '../utils/types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const key = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const base = Astro.site ?? new URL('http://localhost:4321');
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const redirectUrl = new URL(`${path}?sent=1`, base).href;
const subject = lang === 'ar' ? `رسالة من الموقع — ${site.shortNameAr}` : `Website message — ${site.shortNameEn}`;
---

<section class="rounded-lg border border-brand-navy/10 bg-white p-6 shadow-sm" aria-labelledby="contact-form-heading">
  <h2 id="contact-form-heading" class="text-xl font-semibold text-brand-navy">
    {t.contactFormHeading}
  </h2>

  {
    Astro.url.searchParams.has('sent') && (
      <p class="mt-4 rounded-md border border-brand-gold/40 bg-brand-cream px-4 py-3 text-sm text-brand-ink" role="status">
        {t.formSuccess}
      </p>
    )
  }

  {
    !key || key === 'REPLACE_ME' ? (
      <p class="mt-4 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">{t.formConfigNotice}</p>
    ) : null
  }

  <form class="mt-6 space-y-4" method="post" action="https://api.web3forms.com/submit">
    <input type="hidden" name="access_key" value={key} />
    <input type="hidden" name="subject" value={subject} />
    <input type="hidden" name="redirect" value={redirectUrl} />

    <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" value="" aria-hidden="true" />

    <div>
      <label for="cf-name" class="block text-sm font-medium text-brand-ink">
        {t.formName}
      </label>
      <input
        id="cf-name"
        name="name"
        required
        autocomplete="name"
        class="mt-2 w-full rounded-md border border-brand-navy/15 bg-white px-3 py-2 text-brand-ink shadow-sm focus:border-brand-gold focus:outline-none focus:ring-2 focus:ring-brand-gold/30"
      />
    </div>

    <div>
      <label for="cf-phone" class="block text-sm font-medium text-brand-ink">
        {t.formPhone}
      </label>
      <input
        id="cf-phone"
        name="phone"
        required
        inputmode="tel"
        autocomplete="tel"
        class="mt-2 w-full rounded-md border border-brand-navy/15 bg-white px-3 py-2 text-brand-ink shadow-sm focus:border-brand-gold focus:outline-none focus:ring-2 focus:ring-brand-gold/30"
      />
    </div>

    <div>
      <label for="cf-practice" class="block text-sm font-medium text-brand-ink">
        {t.formPractice}
      </label>
      <select
        id="cf-practice"
        name="practice_area"
        required
        class="mt-2 w-full rounded-md border border-brand-navy/15 bg-white px-3 py-2 text-brand-ink shadow-sm focus:border-brand-gold focus:outline-none focus:ring-2 focus:ring-brand-gold/30"
      >
        <option value="" disabled selected>
          {t.formPracticePlaceholder}
        </option>
        {
          practiceAreas.map((area) => (
            <option value={area.slug}>{lang === 'ar' ? area.titleAr : area.titleEn}</option>
          ))
        }
        <option value="other">{t.formPracticeOther}</option>
      </select>
    </div>

    <div>
      <label for="cf-message" class="block text-sm font-medium text-brand-ink">
        {t.formMessage}
      </label>
      <textarea
        id="cf-message"
        name="message"
        required
        rows="6"
        class="mt-2 w-full rounded-md border border-brand-navy/15 bg-white px-3 py-2 text-brand-ink shadow-sm focus:border-brand-gold focus:outline-none focus:ring-2 focus:ring-brand-gold/30"
      />
    </div>

    <p class="text-xs text-brand-muted">{t.formPrivacyNote}</p>

    <button
      type="submit"
      class="inline-flex w-full items-center justify-center rounded-md bg-brand-navy px-4 py-3 text-sm font-semibold text-brand-cream hover:bg-brand-navy/90 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
      disabled={!key || key === 'REPLACE_ME'}
    >
      {t.formSubmit}
    </button>
  </form>
</section>
